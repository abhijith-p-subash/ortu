{
  "name": "ortu",
  "version": "2.0.0",
  "description": "Ortu — a fast, local-first, privacy-focused clipboard manager built with Tauri, Rust, and SvelteKit.",
  "author": "Abhijith P Subash",
  "homepage": "https://ortu.abhijithpsubash.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhijith-p-subash/ortu.git"
  },
  "bugs": {
    "url": "https://github.com/abhijith-p-subash/ortu/issues"
  },
  "keywords": [
    "clipboard",
    "clipboard-manager",
    "tauri",
    "rust",
    "svelte",
    "sveltekit",
    "productivity",
    "local-first",
    "privacy"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "version-up": "node update-version.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "autoprefixer": "^10.4.20",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.9",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}