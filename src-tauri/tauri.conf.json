{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ortu",
  "version": "2.0.0",
  "identifier": "com.ortu.clipboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Ortu",
        "label": "main",
        "width": 1000,
        "height": 700,
        "theme": "Dark",
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://localhost:* http://127.0.0.1:* https://api.github.com"
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/abhijith-p-subash/ortu/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzRTU4OTRFN0EyQjI2MjMKUldRakppdDZUb25sczdOc2RDRVBDQmszTlBHdXMxT2EwTGhkL3kwdTJDMEhNcUxNT2ljcSt0S1QK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "src/installer.nsh"
      }
    }
  }
}